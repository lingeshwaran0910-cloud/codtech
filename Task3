        ("Thanks again for the birthday gift, I really loved it.", "ham"),
    ]
    return pd.DataFrame(data, columns=["message", "label"])


# 1. Load the dataset
df = load_data()
print(f"Dataset size: {len(df)} messages")
print(df["label"].value_counts())
print("\nSample rows:")
print(df.sample(5, random_state=1))

X = df["message"]
y = df["label"]

# 2. Split into training and testing sets
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.25, random_state=42, stratify=y
)

# 3. Convert text to TF-IDF features
vectorizer = TfidfVectorizer(stop_words="english", lowercase=True)
X_train_tfidf = vectorizer.fit_transform(X_train)
X_test_tfidf = vectorizer.transform(X_test)

# 4. Train the model
model = MultinomialNB()
model.fit(X_train_tfidf, y_train)

# 5. Evaluate
y_pred = model.predict(X_test_tfidf)
accuracy = accuracy_score(y_test, y_pred)

print(f"\nModel Accuracy: {accuracy * 100:.2f}%")
print("\nConfusion Matrix (rows=actual, cols=predicted) [ham, spam]:")
print(confusion_matrix(y_test, y_pred, labels=["ham", "spam"]))
print("\nClassification Report:")
print(classification_report(y_test, y_pred))

# 6. Test on new, unseen messages
new_messages = [
    "Congratulations! You've been selected to win a free vacation, click now!",
    "Hey, can we reschedule our call to tomorrow morning?",
    "URGENT: verify your account now to avoid suspension",
    "Let's grab dinner this Friday, my treat!",
]
new_tfidf = vectorizer.transform(new_messages)
predictions = model.predict(new_tfidf)

print("\nPredictions on new messages:")
for msg, pred in zip(new_messages, predictions):
    print(f"  [{pred.upper():5}] {msg}")
