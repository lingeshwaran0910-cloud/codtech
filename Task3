import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix


def load_data():
    """A small labeled sample of spam and ham messages."""
    data = [
        # --- spam ---
        ("Congratulations! You've won a $1000 Walmart gift card. Click here to claim now!", "spam"),
        ("URGENT: Your account has been suspended. Verify your details immediately to avoid closure.", "spam"),
        ("FREE entry into our $5000 prize draw, text WIN to 80086 now!", "spam"),
        ("You have been selected for a cash reward. Reply now to claim your prize.", "spam"),
        ("Get rich quick! Invest $100 today and earn $10,000 in a week guaranteed.", "spam"),
        ("Limited time offer! Buy one get one free, click the link to shop now.", "spam"),
        ("Your loan of $50,000 has been approved. Click here to receive funds instantly.", "spam"),
        ("Hot singles in your area are waiting to chat with you tonight!", "spam"),
        ("Claim your free iPhone now, just pay shipping and handling fee.", "spam"),
        ("WINNER!! As a valued customer you have been selected to receive a prize.", "spam"),
        ("Lowest price on Viagra online, no prescription needed, order now.", "spam"),
        ("Act now! Your credit score qualifies you for an exclusive cash offer.", "spam"),
        ("Congratulations, you have won a lottery of 1,000,000 dollars, contact us to claim.", "spam"),
        ("Make money from home, earn $500 a day with no experience required.", "spam"),
        ("This is your final notice, pay now to avoid legal action against you.", "spam"),
        ("Click this link to unlock exclusive discounts up to 90% off today only.", "spam"),
        ("You've been chosen for a free cruise vacation, call now to reserve your spot.", "spam"),
        ("Verify your bank account now or it will be permanently locked.", "spam"),
        ("Earn extra cash working online, no skills needed, sign up today.", "spam"),
        ("Your package delivery failed, click here to reschedule and pay a small fee.", "spam"),
        # --- ham ---
        ("Hey, are we still meeting for lunch tomorrow at noon?", "ham"),
        ("Can you send me the report before the end of the day?", "ham"),
        ("Thanks for your help with the presentation, it went really well.", "ham"),
        ("Don't forget to pick up milk and eggs on your way home.", "ham"),
        ("The meeting has been rescheduled to 3 PM on Thursday.", "ham"),
        ("Happy birthday! Hope you have a wonderful day.", "ham"),
        ("Let's catch up over coffee sometime next week.", "ham"),
        ("I attached the project files you asked for, let me know if anything's missing.", "ham"),
        ("Can you review my code before I push it to the main branch?", "ham"),
        ("Mom said dinner will be ready around 7 tonight.", "ham"),
        ("The flight got delayed by two hours, we'll land around 9 PM.", "ham"),
